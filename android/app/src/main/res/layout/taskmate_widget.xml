<?xml version="1.0" encoding="utf-8"?>
<!-- RemoteViews only supports a fixed allowlist of view types. Use ImageView
     for divider lines — bare <View> is NOT supported and causes inflation failure. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:padding="14dp">

    <!-- Accent top border (color set dynamically) -->
    <ImageView
        android:id="@+id/widget_accent_bar"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginBottom="10dp"
        android:background="#10B981"
        android:contentDescription="@null" />

    <!-- TASKMATE label -->
    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TASKMATE"
        android:textColor="#555555"
        android:textSize="9sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp" />

    <!-- Task count row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_tasks_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#10B981"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="tasks today"
            android:textColor="#555555"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Next alarm / event -->
    <TextView
        android:id="@+id/widget_next_alarm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next alarm — --:--"
        android:textColor="#EBEBEB"
        android:textSize="11sp"
        android:layout_marginBottom="8dp" />

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A"
        android:layout_marginBottom="8dp"
        android:contentDescription="@null" />

    <!-- Task preview -->
    <TextView
        android:id="@+id/widget_task_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All clear today"
        android:textColor="#555555"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="@null" />

    <!-- Daily Non-Negotiables -->
    <TextView
        android:id="@+id/widget_nonneg_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NON-NEGOTIABLES"
        android:textColor="#555555"
        android:textSize="9sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="3dp" />

    <TextView
        android:id="@+id/widget_nonneg_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#EBEBEB"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
